{
  "$schema": "https://design-tokens.org/schema.json",
  "primitive": {
    "color": {
      "cream": {
        "50": { "$value": "#FBF3E6", "$type": "color" },
        "100": { "$value": "#F3E4C9", "$type": "color" },
        "300": { "$value": "#E2CBA0", "$type": "color" }
      },
      "ink": {
        "900": { "$value": "#241A12", "$type": "color" },
        "700": { "$value": "#4A392B", "$type": "color" },
        "500": { "$value": "#7A6650", "$type": "color" }
      },
      "terracotta": {
        "400": { "$value": "#DD7248", "$type": "color" },
        "500": { "$value": "#C1502E", "$type": "color" },
        "700": { "$value": "#8A3820", "$type": "color" },
        "900": { "$value": "#4A2013", "$type": "color" }
      },
      "teal": {
        "600": { "$value": "#2B6960", "$type": "color" },
        "800": { "$value": "#16332E", "$type": "color" }
      }
    },
    "font": {
      "display": { "$value": "var(--font-dm-serif), 'DM Serif Display', Georgia, serif", "$type": "fontFamily" },
      "sans": { "$value": "var(--font-dm-sans), 'DM Sans', system-ui, sans-serif", "$type": "fontFamily" }
    },
    "motion": {
      "duration": {
        "micro": { "$value": "180ms", "$type": "duration" },
        "base": { "$value": "320ms", "$type": "duration" },
        "reveal": { "$value": "1.1s", "$type": "duration" },
        "cine": { "$value": "1.8s", "$type": "duration" }
      },
      "ease": {
        "out-expo": { "$value": "cubic-bezier(0.16, 1, 0.3, 1)", "$type": "cubicBezier" },
        "cine": { "$value": "cubic-bezier(0.65, 0, 0.35, 1)", "$type": "cubicBezier" }
      }
    },
    "tracking": {
      "display": { "$value": "-0.01em", "$type": "dimension" },
      "label": { "$value": "0.26em", "$type": "dimension" }
    }
  },
  "semantic": {
    "background": { "$value": "{primitive.color.cream.50}", "$type": "color" },
    "foreground": { "$value": "{primitive.color.ink.900}", "$type": "color" },
    "card": { "$value": "{primitive.color.cream.100}", "$type": "color" },
    "card-foreground": { "$value": "{primitive.color.ink.900}", "$type": "color" },
    "muted": { "$value": "{primitive.color.cream.100}", "$type": "color" },
    "muted-foreground": { "$value": "{primitive.color.ink.700}", "$type": "color" },
    "accent": { "$value": "{primitive.color.cream.300}", "$type": "color" },
    "accent-foreground": { "$value": "{primitive.color.ink.900}", "$type": "color" },
    "border": { "$value": "{primitive.color.cream.300}", "$type": "color" },
    "ring": { "$value": "{primitive.color.terracotta.500}", "$type": "color" },
    "radius": { "$value": "1.05rem", "$type": "dimension" },
    "ember": { "$value": "{primitive.color.terracotta.500}", "$type": "color" },
    "ember-dim": { "$value": "{primitive.color.terracotta.900}", "$type": "color" },
    "teal": { "$value": "{primitive.color.teal.600}", "$type": "color" },
    "surface-line": { "$value": "{primitive.color.cream.300}", "$type": "color" },
    "type-display": { "$value": "{primitive.font.display}", "$type": "fontFamily" },
    "type-body": { "$value": "{primitive.font.sans}", "$type": "fontFamily" },
    "ease-reveal": { "$value": "{primitive.motion.ease.out-expo}", "$type": "cubicBezier" },
    "ease-cine": { "$value": "{primitive.motion.ease.cine}", "$type": "cubicBezier" },
    "duration-micro": { "$value": "{primitive.motion.duration.micro}", "$type": "duration" },
    "duration-base": { "$value": "{primitive.motion.duration.base}", "$type": "duration" },
    "duration-reveal": { "$value": "{primitive.motion.duration.reveal}", "$type": "duration" },
    "tracking-display": { "$value": "{primitive.tracking.display}", "$type": "dimension" },
    "tracking-label": { "$value": "{primitive.tracking.label}", "$type": "dimension" }
  },
  "component": {
    "hero": {
      "title-size": { "$value": "clamp(2.7rem, 7.2vw, 6rem)", "$type": "dimension" },
      "title-leading": { "$value": "1.03", "$type": "number" },
      "glow": {
        "$value": "radial-gradient(ellipse 65% 50% at 50% 100%, rgba(221, 114, 72, 0.28), rgba(74, 32, 19, 0.12) 45%, transparent 72%)",
        "$type": "gradient"
      },
      "vignette": {
        "$value": "linear-gradient(to top, rgba(24, 15, 10, 0.96) 0%, rgba(24, 15, 10, 0.32) 42%, rgba(24, 15, 10, 0.55) 100%)",
        "$type": "gradient"
      }
    },
    "button": {
      "primary-bg": { "$value": "{primitive.color.terracotta.500}", "$type": "color" },
      "primary-fg": { "$value": "{primitive.color.cream.50}", "$type": "color" },
      "primary-hover-bg": { "$value": "{primitive.color.terracotta.700}", "$type": "color" },
      "ghost-border": { "$value": "rgba(36, 26, 18, 0.22)", "$type": "color" },
      "ghost-hover-border": { "$value": "{primitive.color.terracotta.500}", "$type": "color" }
    }
  }
}
